import SectionNav from '../../components/SectionNav/SectionNav';
import '../../styles/post-content.css';
import { getPost } from '../../data/posts';

const post = getPost('harness-agentic-control');

const sections = [
  { id: 'thesis', icon: '◈', label: 'Tesis' },
  { id: 'definitions', icon: '≡', label: 'Definiciones' },
  { id: 'model', icon: '⬡', label: 'Modelo' },
  { id: 'evidence', icon: '✓', label: 'Hechos verificados' },
  { id: 'hypotheses', icon: '⚠', label: 'Hipótesis' },
  { id: 'tradeoffs', icon: '▣', label: 'Tradeoffs' },
  { id: 'patterns', icon: '⧉', label: 'Patrones' },
  { id: 'evaluation', icon: '∑', label: 'Evaluación' },
  { id: 'future', icon: '→', label: 'Futuro' },
  { id: 'summary', icon: '⊕', label: 'Resumen' },
