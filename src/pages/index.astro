---
import { Image } from 'astro:assets';

import { getPublishedPosts } from '@/data/posts';
import Base from '@/layouts/Base.astro';
import '@/styles/post-list.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const posts = await getPublishedPosts();

function formatDate(dateStr: string): string {
  // Parse YYYY-MM-DD manually to avoid timezone issues
  const [year, month, day] = dateStr.split('-').map(Number);
  // month is 0-indexed in Date constructor
  const date = new Date(year, month - 1, day);
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC', // Keep UTC to preserve the exact date
  });
}
---

<Base
  title="The SE Blog"
  description="Where systems thinking meets applied intelligence."
  isHome={true}
  showBackground={false}
>
  <div class="homepage-content">
    <p class="tagline">Where systems thinking meets applied intelligence.</p>

    <div class="post-list">
      {
        posts.map((post, index) => (
          <a
            href={`${base}/blog/${post.id}`}
            class="post-card"
            style={`--card-delay: ${index * 80}ms;`}
          >
            <h2 class="post-title">{post.title}</h2>
            {(post.icon || post.description) && (
              <div class="post-summary">
                {post.icon && (
                  <div class="post-icon">
                    <Image
                      src={post.icon}
                      alt={post.iconAlt ?? post.title}
                      class="post-icon__image"
                      width={56}
                      height={56}
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                )}
                {post.description && <p class="post-desc">{post.description}</p>}
              </div>
            )}
            <div class="post-footer">
              <div class="post-tags">
                {post.tags.map((tag) => (
                  <span class="post-tag">{tag}</span>
                ))}
              </div>
              <span class="post-date">{formatDate(post.pubDate)}</span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</Base>

<style></style>
