---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<Base
  title="Software Engineering Blog"
  description="Where systems thinking meets applied intelligence."
>
  <p class="tagline">Where systems thinking meets applied intelligence.</p>

  <div class="post-list">
    <a href={`${base}/blog/llm-context-limitations`} class="post-card">
      <div class="post-meta">
        <span class="post-date">Apr 1, 2026</span>
        <span class="post-tag">llm</span>
        <span class="post-tag">context</span>
      </div>
      <h2 class="post-title">Limitaciones de los LLM en la actualidad</h2>
      <p class="post-desc">Ventana de contexto, Smart Context y estrategias para ahorrar tokens</p>
    </a>

    <a href={`${base}/blog/harness-engineering`} class="post-card">
      <div class="post-meta">
        <span class="post-tag">guide</span>
      </div>
      <h2 class="post-title">Harness Engineering</h2>
      <p class="post-desc">Guía práctica · OpenCode + Sub-agentes</p>
    </a>

    <a href={`${base}/blog/bienvenidos`} class="post-card">
      <div class="post-meta">
        <span class="post-date">Apr 2, 2026</span>
        <span class="post-tag">meta</span>
      </div>
      <h2 class="post-title">Bienvenidos al blog</h2>
      <p class="post-desc">Punto de partida · De qué va este espacio</p>
    </a>

    {
      posts.map((post) => (
        <a href={`${base}/blog/${post.id}`} class="post-card">
          <div class="post-meta">
            <span class="post-date">{formatDate(post.data.pubDate)}</span>
            {post.data.tags.map((tag) => (
              <span class="post-tag">{tag}</span>
            ))}
          </div>
          <h2 class="post-title">{post.data.title}</h2>
          {post.data.description && <p class="post-desc">{post.data.description}</p>}
        </a>
      ))
    }
  </div>
</Base>

<style>
</style>
