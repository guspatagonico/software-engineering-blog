---
import Base from '@/layouts/Base.astro';
---

<Base title="Contact" description="Get in touch.">
  <h1>Contact</h1>
  <p class="subtitle">Get in touch</p>

  <div class="content">
    <div class="link-grid">
      <a href="https://github.com/guspatagonico" class="link-card" target="_blank" rel="noopener">
        <span class="link-label">GitHub</span>
        <span class="link-value">guspatagonico</span>
      </a>
      <a href="https://x.com/guspatagonico" class="link-card" target="_blank" rel="noopener">
        <span class="link-label">X (Twitter)</span>
        <span class="link-value">@guspatagonico</span>
      </a>
      <a href="https://gustavosalvini.com.ar" class="link-card" target="_blank" rel="noopener">
        <span class="link-label">Website</span>
        <span class="link-value">gustavosalvini.com.ar</span>
      </a>
    </div>
  </div>
</Base>

<style>
  .subtitle {
    font-size: 12px;
    font-weight: 600;
    color: var(--text-dim);
    margin-bottom: 32px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .link-grid {
    display: grid;
    gap: 12px;
  }

  .link-card {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 16px 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 5px;
    transition: border-color 0.15s;
  }

  .link-card:hover {
    border-color: var(--teal);
    text-decoration: none;
  }

  .link-label {
    font-size: 12px;
    font-weight: 700;
    color: var(--teal);
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .link-value {
    font-size: 14px;
    color: var(--text-bright);
  }
</style>
