---
import '../styles/global.css';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import ScrollIndicator from '@/components/ScrollIndicator.astro';
import Head from '@/components/Head/Head.astro';
import type { PostMeta } from '@/data/posts';

interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  post?: PostMeta;
}

const { title, subtitle, description, post } = Astro.props;
const finalDescription = description ?? post?.description;
---

<html lang="en">
  <head>
    <Head
      title={title}
      description={finalDescription}
      type="article"
      publishedTime={post?.pubDate}
      tags={post?.tags}
    />
  </head>
  <body>
    <Navbar />
    <ScrollIndicator targetSelector=".content" position="fixed" top="48px" />
    <header class="post-header">
      <h1>{title}</h1>
      {subtitle && <span class="post-subtitle">{subtitle}</span>}
    </header>
    <div class="post-layout">
      <slot />
    </div>
    
    <!-- Post Meta Footer - Date and Tags (anchored right, above global footer) -->
    {post && (
      <div class="post-meta-footer">
        <div class="post-meta-inner">
          <span class="post-meta-label">Published</span>
          <span class="post-meta-date">{post.pubDate}</span>
        </div>
        {post.tags.length > 0 && (
          <div class="post-meta-tags">
            {post.tags.map((tag) => (
              <span class="post-tag">{tag}</span>
            ))}
          </div>
        )}
      </div>
    )}
    
    <Footer />

    <!-- Handle URL hash for section navigation -->
    <script is:inline>
      (function() {
        // Wait for React components to hydrate
        function initHashNavigation() {
          const hash = window.location.hash.slice(1);
          if (!hash) return;

          // Find the panel matching the hash
          const panel = document.getElementById('panel-' + hash);
          if (!panel) return;

          // Activate the panel
          document.querySelectorAll('.panel').forEach((p) => {
            p.classList.remove('active');
          });
          panel.classList.add('active');

          // Scroll to panel on mobile/tablet
          const isMobile = window.innerWidth < 1024;
          if (isMobile) {
            setTimeout(() => {
              panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, 100);
          }

          // Dispatch a custom event so SectionNav can sync its state
          window.dispatchEvent(new CustomEvent('section-activated', {
            detail: { sectionId: hash }
          }));
        }

        // Run on load and when DOM is ready
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initHashNavigation);
        } else {
          // Small delay to let React hydrate first
          setTimeout(initHashNavigation, 50);
        }

        // Also run after Astro page transitions
        document.addEventListener('astro:page-load', initHashNavigation);
      })();
    </script>
  </body>
</html>

<style>
  body {
    display: flex;
    flex-direction: column;
    height: 100dvh;
    overflow: hidden;
  }

  .post-header {
    padding: 20px 28px 16px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: baseline;
    gap: 16px;
    background: var(--surface);
    position: sticky;
    top: 48px;
    z-index: 40;
  }

  .post-layout {
    flex: 1;
    display: flex;
    min-height: 0;
    position: relative;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .post-layout::-webkit-scrollbar {
    display: none;
  }

  /* Desktop: fixed section nav, scrolling content */
  @media (min-width: 1024px) {
    .post-layout {
      overflow: hidden;
    }

    .post-layout > nav {
      position: sticky;
      top: calc(48px + 60px);
      height: calc(100vh - 48px - 60px - 70px);
      overflow-y: auto;
      flex-shrink: 0;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .post-layout > nav::-webkit-scrollbar {
      display: none;
    }
  }

  /* Tablet */
  @media (min-width: 768px) and (max-width: 1023px) {
    .post-layout {
      flex-direction: column;
      overflow-y: auto;
    }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .post-layout {
      flex-direction: column;
      overflow-y: auto;
      overscroll-behavior: none;
    }

    .post-header {
      padding: 16px;
      flex-direction: column;
      gap: 8px;
    }

    .post-header h1 {
      font-size: 16px;
    }

    .post-subtitle {
      font-size: 10px;
    }
  }

  .post-layout::-webkit-scrollbar {
    display: none;
  }

  .post-header h1 {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-bright);
    letter-spacing: -0.4px;
  }

  .post-subtitle {
    font-size: 12px;
    font-weight: 600;
    color: var(--teal);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  /* Tablet */
  @media (min-width: 768px) and (max-width: 1023px) {
    .post-header {
      padding: 18px 20px;
    }

    .post-header h1 {
      font-size: 17px;
    }

    .post-layout {
      flex-direction: column;
    }
  }

  /* Post Meta Footer - Anchored to right above global footer */
  .post-meta-footer {
    position: fixed;
    bottom: 70px; /* Height of global footer + spacing */
    right: 0;
    padding:8px 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-right: none;
    border-radius: 6px 0 0 6px;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
    z-index: 35;
    max-width: 280px;
    box-shadow: -2px 0 8px rgba(0, 0, 0, 0.2);
  }

  .post-meta-inner {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .post-meta-label {
    font-size: 10px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .post-meta-date {
    font-size: 12px;
    color: var(--text-bright);
    font-weight: 500;
  }

  .post-meta-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .post-tag {
    font-size: 9px;
    font-weight: 700;
    color: var(--teal);
    background: rgba(0, 212, 170, 0.15);
    padding: 3px 8px;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 1px;
    border: 1px solid rgba(0, 212, 170, 0.3);
  }

  /* Desktop */
  @media (min-width: 1400px) {
    .post-meta-footer {
      bottom: 70px;
      right: 0;
    }
  }

  /* Tablet & Mobile - same full-width layout above footer */
  @media (max-width: 1399px) {
    .post-meta-footer {
      position: fixed;
      bottom: 59px; /* Footer: padding 12px*2 + border 1px + content ~16px = 47px */
      /* bottom: 53px; */
      left: 0;
      right: 0;
      max-width: none;
      border-radius: 0;
      border-right: none;
      border-left: none;
      border-top: 1px solid var(--border);
      border-bottom: none;
      box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.2);
      margin: 0;
      padding: 6px 16px; /* Reduced vertical padding */
      flex-direction: row;
      align-items: center;
      justify-content: flex-start;
      gap: 16px;
      flex-wrap: wrap;
      z-index: 45; /* Below footer (50) but above content */
    }
  }

  /* Smaller screens - footer has less padding */
  @media (max-width: 480px) {
    .post-meta-footer {
      bottom: 47px; /* Footer: padding 12px*2 + border 1px + content ~16px = 47px */
      padding: 5px 16px;
    }
  }

  /* Tablet & Mobile inner elements */
  @media (max-width: 1023px) {
    .post-meta-inner {
      flex-shrink: 0;
    }

    .post-meta-tags {
      flex: 1;
      min-width: 0;
    }

    .post-tag {
      flex-shrink: 0;
      padding: 2px 6px; /* Reduced padding for mobile/tablet */
      font-size: 9px;
    }
  }
</style>
