---
import '../styles/global.css';
import '../styles/blog-post.css';

import { Image } from 'astro:assets';

import Head from '@/components/Head/Head.astro';
import Footer from '@/components/Footer.astro';
import Navbar from '@/components/Navbar.astro';
import PostCompactFooter from '@/components/PostCompactFooter.astro';
import ScrollIndicator from '@/components/ScrollIndicator.astro';
import type { PostMeta } from '@/data/posts';

interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  post?: PostMeta;
}

const { title, subtitle, description, post } = Astro.props;
const finalDescription = description ?? post?.description;
---

<html lang="en">
  <head>
    <Head
      title={title}
      description={finalDescription}
      image={post?.ogImage?.src ?? post?.icon?.src}
      type="article"
      publishedTime={post?.pubDate}
      tags={post?.tags}
    />
    <script is:inline>
      (function () {
        if (window.matchMedia('(max-width: 767px)').matches) {
          document.documentElement.dataset.sectionsCollapsed = 'true';
        }
      })();
    </script>
    <script is:inline>
      (function () {
        function moveTagsInline() {
          const tags = document.querySelector('[data-post-tags]');
          const content = document.querySelector('.content');
          if (!tags || !content) return;
          if (content.contains(tags)) return;
          tags.removeAttribute('hidden');
          content.appendChild(tags);
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', moveTagsInline);
        } else {
          moveTagsInline();
        }

        document.addEventListener('astro:page-load', moveTagsInline);
      })();
    </script>
    <script is:inline>
      (function () {
        document.documentElement.dataset.contentLoading = 'true';
        function clearLoading() {
          requestAnimationFrame(function () {
            delete document.documentElement.dataset.contentLoading;
          });
        }
        window.addEventListener('load', clearLoading, { once: true });
        document.addEventListener('astro:page-load', clearLoading, { once: true });
      })();
    </script>
    <script is:inline>
      (function () {
        const hash = window.location.hash.slice(1);
        if (hash) {
          document.documentElement.dataset.panelSyncing = 'true';
          document.documentElement.dataset.sectionsSyncing = 'true';
          document.documentElement.dataset.currentPanel = hash;
        }

        if (window.matchMedia('(max-width: 767px)').matches) {
          document.documentElement.dataset.sectionsCollapsed = 'true';
        }
      })();
    </script>
    <script is:inline>
      (function () {
        const root = document.documentElement;
        const threshold = 12;
        const hysteresis = 16;
        const mobileQuery = window.matchMedia('(max-width: 767px)');
        let lastCompact = null;

        function isMobile() {
          return mobileQuery.matches;
        }

        function getScrollMetrics() {
          const content = document.querySelector('.content');
          if (content && content.scrollHeight > content.clientHeight) {
            return {
              scrollTop: content.scrollTop,
              scrollHeight: content.scrollHeight,
              clientHeight: content.clientHeight,
            };
          }
          const layout = document.querySelector('.post-layout');
          if (layout && layout.scrollHeight > layout.clientHeight) {
            return {
              scrollTop: layout.scrollTop,
              scrollHeight: layout.scrollHeight,
              clientHeight: layout.clientHeight,
            };
          }
          const scrollTop = window.scrollY || document.documentElement.scrollTop;
          return {
            scrollTop,
            scrollHeight: document.documentElement.scrollHeight,
            clientHeight: document.documentElement.clientHeight,
          };
        }

        function setHeaderHeight() {
          const header = document.querySelector('.post-header');
          if (!header) return;
          const height = Math.round(header.getBoundingClientRect().height);
          root.style.setProperty('--post-header-height', `${height}px`);
        }

        function updateCompact() {
          if (!isMobile()) {
            if (lastCompact !== false) {
              root.dataset.headerCompact = 'false';
              lastCompact = false;
              requestAnimationFrame(setHeaderHeight);
            }
            return;
          }

          const { scrollTop, scrollHeight, clientHeight } = getScrollMetrics();
          const maxScroll = Math.max(0, scrollHeight - clientHeight);
          const upper = threshold + hysteresis;
          const lower = Math.max(0, threshold - hysteresis);
          const minScrollForCompact = upper + 56;

          if (maxScroll < minScrollForCompact) {
            if (lastCompact !== false) {
              root.dataset.headerCompact = 'false';
              lastCompact = false;
              requestAnimationFrame(setHeaderHeight);
            }
            return;
          }

          let shouldCompact;
          if (lastCompact === null) {
            shouldCompact = scrollTop > upper;
          } else if (lastCompact) {
            shouldCompact = scrollTop > lower;
          } else {
            shouldCompact = scrollTop > upper;
          }
          if (shouldCompact !== lastCompact) {
            root.dataset.headerCompact = shouldCompact ? 'true' : 'false';
            lastCompact = shouldCompact;
            requestAnimationFrame(setHeaderHeight);
          }
        }

        function refresh() {
          bindListeners();
          setHeaderHeight();
          updateCompact();
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', refresh);
        } else {
          refresh();
        }

        function bindListeners() {
          const content = document.querySelector('.content');
          const layout = document.querySelector('.post-layout');
          if (content && content.dataset.headerCompactBound !== 'true') {
            content.dataset.headerCompactBound = 'true';
            content.addEventListener('scroll', updateCompact, { passive: true });
          }
          if (layout && layout.dataset.headerCompactBound !== 'true') {
            layout.dataset.headerCompactBound = 'true';
            layout.addEventListener('scroll', updateCompact, { passive: true });
          }
          if (root.dataset.headerCompactWindowBound !== 'true') {
            root.dataset.headerCompactWindowBound = 'true';
            window.addEventListener('scroll', updateCompact, { passive: true });
          }
        }

        window.addEventListener('load', refresh, { once: true });
        window.addEventListener('resize', refresh, { passive: true });
        document.addEventListener('astro:page-load', () => {
          setTimeout(refresh, 0);
        });
      })();
    </script>
  </head>
  <body class="post-page">
    <Navbar />
    <ScrollIndicator targetSelector=".content" position="fixed" top="48px" />
    <header class="post-header">
      {
        post?.icon && (
          <div class="post-header__icon">
            <Image
              src={post.icon}
              alt={post.iconAlt ?? title}
              class="post-header__icon-image"
              width={64}
              height={64}
              loading="eager"
              decoding="async"
            />
          </div>
        )
      }
      <div class="post-header__text">
        <h1>{title}</h1>
        {subtitle && <span class="post-subtitle">{subtitle}</span>}
      </div>
    </header>
    <div class="post-layout">
      <slot />
    </div>

    {post && <PostCompactFooter published={post.pubDate} />}

    {
      post && post.tags.length > 0 && (
        <div class="post-tags-inline" data-post-tags hidden>
          <div class="post-tags-inline__list">
            {post.tags.map((tag) => (
              <span class="post-tag">{tag}</span>
            ))}
          </div>
        </div>
      )
    }

    <Footer />

    <!-- Handle URL hash for section navigation -->
    <script is:inline>
      (function () {
        // Wait for React components to hydrate
        function initHashNavigation() {
          const hash = window.location.hash.slice(1);
          if (!hash) {
            delete document.documentElement.dataset.panelSyncing;
            delete document.documentElement.dataset.sectionsSyncing;
            return;
          }

          // Find the panel matching the hash
          const panel = document.getElementById('panel-' + hash);
          if (!panel) return;

          // Activate the panel
          document.querySelectorAll('.panel').forEach((p) => {
            p.classList.remove('active');
          });
          panel.classList.add('active');

          setTimeout(() => {
            const content = document.querySelector('.content');
            const scrollContainer = document.querySelector('.post-layout');

            if (content && content.scrollHeight > content.clientHeight) {
              content.scrollTo({ top: 0, behavior: 'smooth' });
            } else if (scrollContainer) {
              scrollContainer.scrollTo({ top: 0, behavior: 'smooth' });
            } else {
              window.scrollTo({ top: 0, behavior: 'smooth' });
            }
          }, 100);

          // Dispatch a custom event so SectionNav can sync its state
          window.dispatchEvent(
            new CustomEvent('section-activated', {
              detail: { sectionId: hash },
            })
          );

          delete document.documentElement.dataset.panelSyncing;
          delete document.documentElement.dataset.sectionsSyncing;
        }

        // Run on load and when DOM is ready
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initHashNavigation);
        } else {
          // Small delay to let React hydrate first
          setTimeout(initHashNavigation, 50);
        }

        // Also run after Astro page transitions
        document.addEventListener('astro:page-load', initHashNavigation);
      })();
    </script>
    <script src="/software-engineering/vendor/mermaid.min.js" defer></script>
    <script src="/software-engineering/vendor/mermaid-render.js" defer></script>
  </body>
</html>
