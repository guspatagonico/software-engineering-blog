---
import '../styles/global.css';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import ScrollIndicator from '@/components/ScrollIndicator.astro';
import Head from '@/components/Head/Head.astro';
import type { PostMeta } from '@/data/posts';

interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  post?: PostMeta;
}

const { title, subtitle, description, post } = Astro.props;
const finalDescription = description ?? post?.description;
---

<html lang="en">
  <head>
    <Head
      title={title}
      description={finalDescription}
      type="article"
      publishedTime={post?.pubDate}
      tags={post?.tags}
    />
    <script is:inline>
      (function () {
        if (window.matchMedia('(max-width: 767px)').matches) {
          document.documentElement.dataset.sectionsCollapsed = 'true';
        }
      })();
    </script>
    <script is:inline>
      (function () {
        document.documentElement.dataset.contentLoading = 'true';
        function clearLoading() {
          requestAnimationFrame(function () {
            delete document.documentElement.dataset.contentLoading;
          });
        }
        window.addEventListener('load', clearLoading, { once: true });
        document.addEventListener('astro:page-load', clearLoading, { once: true });
      })();
    </script>
    <script is:inline>
      (function () {
        const hash = window.location.hash.slice(1);
        if (hash) {
          document.documentElement.dataset.panelSyncing = 'true';
          document.documentElement.dataset.sectionsSyncing = 'true';
          document.documentElement.dataset.currentPanel = hash;
        }

        if (window.matchMedia('(max-width: 767px)').matches) {
          document.documentElement.dataset.sectionsCollapsed = 'true';
        }
      })();
    </script>
    <style is:inline>
      @media (max-width: 767px) {
        :root:not([data-sections-collapsed='false']) .section-nav-toggle__label-text {
          display: none;
        }

        :root:not([data-sections-collapsed='false']) .section-nav-toggle__active {
          display: inline-flex;
        }

        :root:not([data-sections-collapsed='false']) .section-nav-toggle__icon {
          transform: rotate(0deg);
        }
      }
    </style>
  </head>
  <body>
    <Navbar />
    <ScrollIndicator targetSelector=".content" position="fixed" top="48px" />
    <header class="post-header">
      <h1>{title}</h1>
      {subtitle && <span class="post-subtitle">{subtitle}</span>}
    </header>
    <div class="post-layout">
      <slot />
    </div>

    <!-- Post Meta Footer - Date and Tags (anchored right, above global footer) -->
    {
      post && (
        <div class="post-meta-footer">
          <div class="post-meta-inner">
            <span class="post-meta-label">Published</span>
            <span class="post-meta-date">{post.pubDate}</span>
          </div>
          {post.tags.length > 0 && (
            <div class="post-meta-tags">
              {post.tags.map((tag) => (
                <span class="post-tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
      )
    }

    <Footer />

    <!-- Handle URL hash for section navigation -->
    <script is:inline>
      (function () {
        // Wait for React components to hydrate
        function initHashNavigation() {
          const hash = window.location.hash.slice(1);
          if (!hash) {
            delete document.documentElement.dataset.panelSyncing;
            delete document.documentElement.dataset.sectionsSyncing;
            return;
          }

          // Find the panel matching the hash
          const panel = document.getElementById('panel-' + hash);
          if (!panel) return;

          // Activate the panel
          document.querySelectorAll('.panel').forEach((p) => {
            p.classList.remove('active');
          });
          panel.classList.add('active');

          setTimeout(() => {
            const content = document.querySelector('.content');
            const scrollContainer = document.querySelector('.post-layout');

            if (content && content.scrollHeight > content.clientHeight) {
              content.scrollTo({ top: 0, behavior: 'smooth' });
            } else if (scrollContainer) {
              scrollContainer.scrollTo({ top: 0, behavior: 'smooth' });
            } else {
              window.scrollTo({ top: 0, behavior: 'smooth' });
            }
          }, 100);

          // Dispatch a custom event so SectionNav can sync its state
          window.dispatchEvent(
            new CustomEvent('section-activated', {
              detail: { sectionId: hash },
            })
          );

          delete document.documentElement.dataset.panelSyncing;
          delete document.documentElement.dataset.sectionsSyncing;
        }

        // Run on load and when DOM is ready
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initHashNavigation);
        } else {
          // Small delay to let React hydrate first
          setTimeout(initHashNavigation, 50);
        }

        // Also run after Astro page transitions
        document.addEventListener('astro:page-load', initHashNavigation);
      })();
    </script>
    <script is:inline type="module">
      let mermaidRetryTimeout;

      async function renderMermaid(isRerender, attempt = 0) {
        const { default: mermaid } =
          await import('https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs');

        const styles = getComputedStyle(document.documentElement);
        const themeVariables = {
          background: styles.getPropertyValue('--surface').trim(),
          primaryColor: styles.getPropertyValue('--surface2').trim(),
          primaryTextColor: styles.getPropertyValue('--text-bright').trim(),
          primaryBorderColor: styles.getPropertyValue('--border').trim(),
          lineColor: styles.getPropertyValue('--text-dim').trim(),
          secondaryColor: styles.getPropertyValue('--surface').trim(),
          tertiaryColor: styles.getPropertyValue('--bg').trim(),
          textColor: styles.getPropertyValue('--text').trim(),
          fontFamily: styles.getPropertyValue('--font').trim(),
          fontSize: '14px',
          edgeLabelBackground: styles.getPropertyValue('--surface').trim(),
          clusterBkg: styles.getPropertyValue('--surface').trim(),
          clusterBorder: styles.getPropertyValue('--border').trim(),
        };

        mermaid.initialize({
          startOnLoad: false,
          securityLevel: 'loose',
          theme: 'base',
          themeVariables,
        });

        if (!isRerender) {
          document.querySelectorAll('pre > code.language-mermaid').forEach((code) => {
            const pre = code.parentElement;
            if (!pre || pre.dataset.mermaidRendered === 'true') return;
            const container = document.createElement('div');
            container.className = 'mermaid';
            container.dataset.mermaidSource = code.textContent || '';
            container.textContent = code.textContent || '';
            pre.dataset.mermaidRendered = 'true';
            pre.replaceWith(container);
          });
        } else {
          document.querySelectorAll('.mermaid').forEach((node) => {
            const source = node.dataset.mermaidSource;
            if (!source) return;
            node.innerHTML = '';
            node.textContent = source;
          });
        }

        try {
          await mermaid.run({ querySelector: '.mermaid' });
        } catch (error) {
          if (attempt < 1) {
            clearTimeout(mermaidRetryTimeout);
            mermaidRetryTimeout = setTimeout(() => renderMermaid(true, attempt + 1), 150);
          } else {
            console.error('Mermaid render failed', error);
          }
        }
      }

      function scheduleMermaidRender(isRerender) {
        requestAnimationFrame(() => renderMermaid(isRerender));
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => scheduleMermaidRender(false));
      } else {
        scheduleMermaidRender(false);
      }

      document.addEventListener('astro:page-load', () => scheduleMermaidRender(false));

      const observer = new MutationObserver((mutations) => {
        const hasThemeChange = mutations.some((m) => m.attributeName === 'data-theme');
        if (hasThemeChange) scheduleMermaidRender(true);
      });

      observer.observe(document.documentElement, { attributes: true });
    </script>
  </body>
</html>

<style>
  body {
    display: flex;
    flex-direction: column;
    height: 100dvh;
    overflow: hidden;
  }

  .post-header {
    padding: 20px 28px 16px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: baseline;
    gap: 16px;
    background: var(--surface);
    position: sticky;
    top: 48px;
    z-index: 40;
  }

  .post-layout {
    flex: 1;
    display: flex;
    min-height: 0;
    position: relative;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .post-layout::-webkit-scrollbar {
    display: none;
  }

  /* Desktop: fixed section nav, scrolling content */
  @media (min-width: 1024px) {
    .post-layout {
      overflow: hidden;
    }

    .post-layout > nav {
      position: sticky;
      top: calc(48px + 60px);
      height: calc(100vh - 48px - 60px - 70px);
      overflow-y: auto;
      flex-shrink: 0;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .post-layout > nav::-webkit-scrollbar {
      display: none;
    }
  }

  /* Tablet */
  @media (min-width: 768px) and (max-width: 1023px) {
    .post-layout {
      flex-direction: column;
      overflow-y: auto;
    }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .post-layout {
      flex-direction: column;
      overflow-y: auto;
      overscroll-behavior: none;
    }

    .post-header {
      padding: 16px;
      flex-direction: column;
      gap: 8px;
    }

    .post-header h1 {
      font-size: 16px;
    }

    .post-subtitle {
      font-size: 10px;
    }
  }

  .post-layout::-webkit-scrollbar {
    display: none;
  }

  .post-header h1 {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-bright);
    letter-spacing: -0.4px;
  }

  .post-subtitle {
    font-size: 12px;
    font-weight: 600;
    color: var(--teal);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .mermaid {
    margin: 16px 0 18px;
    padding: 18px 20px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: linear-gradient(135deg, rgba(0, 212, 170, 0.08), rgba(10, 12, 18, 0));
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.12);
    overflow: auto;
  }

  .mermaid svg {
    display: block;
    width: 100%;
    height: auto;
    font-size: 14px;
    font-family: var(--font) !important;
  }

  .mermaid svg * {
    font-family: var(--font) !important;
  }

  .mermaid text,
  .mermaid tspan {
    font-family: var(--font);
    font-weight: 600;
    letter-spacing: 0.2px;
    font-size: 14px;
  }

  .mermaid .c4Container,
  .mermaid .c4Container * {
    font-size: 14px;
    font-family: var(--font) !important;
  }

  .mermaid .c4Container .label,
  .mermaid .c4Container .label text,
  .mermaid .c4Container .nodeLabel {
    font-weight: 600;
  }

  .mermaid .label text,
  .mermaid .nodeLabel {
    fill: var(--text-bright);
  }

  .mermaid .edgePath path {
    stroke: var(--text-dim);
  }

  .mermaid .edgeLabel {
    background: rgba(10, 12, 18, 0.85);
    border-radius: 6px;
    padding: 1px 6px;
  }

  .mermaid .node rect,
  .mermaid .node circle,
  .mermaid .node polygon,
  .mermaid .node path {
    stroke-width: 1.2px;
  }

  .mermaid .cluster rect {
    rx: 8px;
    ry: 8px;
  }

  :root[data-theme='light'] .mermaid {
    background: linear-gradient(135deg, rgba(0, 120, 96, 0.08), rgba(255, 255, 255, 0.7));
    border-color: rgba(0, 60, 48, 0.2);
  }

  :root[data-theme='light'] .mermaid .edgeLabel {
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(0, 60, 48, 0.15);
  }

  :root[data-theme='light'] .mermaid .edgePath path {
    stroke: rgba(0, 60, 48, 0.6);
  }

  :root[data-theme='dark'] .mermaid .edgeLabel {
    background: rgba(10, 12, 18, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  /* Tablet */
  @media (min-width: 768px) and (max-width: 1023px) {
    .post-header {
      padding: 18px 20px;
    }

    .post-header h1 {
      font-size: 17px;
    }

    .post-layout {
      flex-direction: column;
    }
  }

  @media (max-width: 767px) {
    .mermaid {
      padding: 14px 12px;
    }
  }

  /* Post Meta Footer - Anchored to right above global footer */
  .post-meta-footer {
    position: fixed;
    bottom: 70px; /* Height of global footer + spacing */
    right: 0;
    padding: 8px 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-right: none;
    border-radius: 6px 0 0 6px;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
    z-index: 35;
    max-width: 280px;
    box-shadow: -2px 0 8px rgba(0, 0, 0, 0.2);
  }

  .post-meta-inner {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .post-meta-label {
    font-size: 10px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .post-meta-date {
    font-size: 12px;
    color: var(--text-bright);
    font-weight: 500;
  }

  .post-meta-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .post-tag {
    font-size: 9px;
    font-weight: 700;
    color: var(--teal);
    background: rgba(0, 212, 170, 0.15);
    padding: 3px 8px;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 1px;
    border: 1px solid rgba(0, 212, 170, 0.3);
  }

  /* Desktop */
  @media (min-width: 1400px) {
    .post-meta-footer {
      bottom: 70px;
      right: 0;
    }
  }

  /* Tablet & Mobile - same full-width layout above footer */
  @media (max-width: 1399px) {
    .post-meta-footer {
      position: fixed;
      bottom: 59px; /* Footer: padding 12px*2 + border 1px + content ~16px = 47px */
      /* bottom: 53px; */
      left: 0;
      right: 0;
      max-width: none;
      border-radius: 0;
      border-right: none;
      border-left: none;
      border-top: 1px solid var(--border);
      border-bottom: none;
      box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.2);
      margin: 0;
      padding: 6px 16px; /* Reduced vertical padding */
      flex-direction: row;
      align-items: center;
      justify-content: flex-start;
      gap: 16px;
      flex-wrap: wrap;
      z-index: 45; /* Below footer (50) but above content */
    }
  }

  /* Smaller screens - footer has less padding */
  @media (max-width: 480px) {
    .post-meta-footer {
      bottom: 47px; /* Footer: padding 12px*2 + border 1px + content ~16px = 47px */
      padding: 5px 16px;
    }
  }

  /* Tablet & Mobile inner elements */
  @media (max-width: 1023px) {
    .post-meta-inner {
      flex-shrink: 0;
    }

    .post-meta-tags {
      flex: 1;
      min-width: 0;
    }

    .post-tag {
      flex-shrink: 0;
      padding: 2px 6px; /* Reduced padding for mobile/tablet */
      font-size: 9px;
    }
  }
</style>
