---
import '../styles/global.css';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import ScrollIndicator from '@/components/ScrollIndicator.astro';
import Head from '@/components/Head/Head.astro';
import { getPost } from '@/data/posts';

interface Props {
  title: string;
  subtitle?: string;
  description?: string;
}

const { title, subtitle, description } = Astro.props;

// Try to get description from posts.ts if not provided as prop
const postId = Astro.url.pathname.split('/').pop();
const post = postId ? getPost(postId) : undefined;
const finalDescription = description ?? post?.description;
---

<html lang="en">
  <head>
    <Head
      title={title}
      description={finalDescription}
      type="article"
      publishedTime={post?.pubDate}
    />
  </head>
  <body>
    <Navbar />
    <ScrollIndicator targetSelector=".content" position="fixed" top="48px" />
    <header class="post-header">
      <h1>{title}</h1>
      {subtitle && <span class="post-subtitle">{subtitle}</span>}
    </header>
    <div class="post-layout">
      <slot />
    </div>
    <Footer />

    <!-- Handle URL hash for section navigation -->
    <script is:inline>
      (function() {
        // Wait for React components to hydrate
        function initHashNavigation() {
          const hash = window.location.hash.slice(1);
          if (!hash) return;

          // Find the panel matching the hash
          const panel = document.getElementById('panel-' + hash);
          if (!panel) return;

          // Activate the panel
          document.querySelectorAll('.panel').forEach((p) => {
            p.classList.remove('active');
          });
          panel.classList.add('active');

          // Scroll to panel on mobile/tablet
          const isMobile = window.innerWidth < 1024;
          if (isMobile) {
            setTimeout(() => {
              panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, 100);
          }

          // Dispatch a custom event so SectionNav can sync its state
          window.dispatchEvent(new CustomEvent('section-activated', {
            detail: { sectionId: hash }
          }));
        }

        // Run on load and when DOM is ready
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initHashNavigation);
        } else {
          // Small delay to let React hydrate first
          setTimeout(initHashNavigation, 50);
        }

        // Also run after Astro page transitions
        document.addEventListener('astro:page-load', initHashNavigation);
      })();
    </script>
  </body>
</html>

<style>
  body {
    display: flex;
    flex-direction: column;
    height: 100dvh;
    overflow: hidden;
  }

  .post-header {
    padding: 20px 28px 16px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: baseline;
    gap: 16px;
    background: var(--surface);
    position: sticky;
    top: 48px;
    z-index: 40;
  }

  .post-layout {
    flex: 1;
    display: flex;
    min-height: 0;
    position: relative;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .post-layout::-webkit-scrollbar {
    display: none;
  }

  /* Desktop: fixed section nav, scrolling content */
  @media (min-width: 1024px) {
    .post-layout {
      overflow: hidden;
    }

    .post-layout > nav {
      position: sticky;
      top: calc(48px + 60px);
      height: calc(100vh - 48px - 60px - 70px);
      overflow-y: auto;
      flex-shrink: 0;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .post-layout > nav::-webkit-scrollbar {
      display: none;
    }
  }

  /* Tablet */
  @media (min-width: 768px) and (max-width: 1023px) {
    .post-layout {
      flex-direction: column;
      overflow-y: auto;
    }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .post-layout {
      flex-direction: column;
      overflow-y: auto;
      overscroll-behavior: none;
    }

    .post-header {
      padding: 16px;
      flex-direction: column;
      gap: 8px;
    }

    .post-header h1 {
      font-size: 16px;
    }

    .post-subtitle {
      font-size: 10px;
    }
  }

  .post-layout::-webkit-scrollbar {
    display: none;
  }

  .post-header h1 {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-bright);
    letter-spacing: -0.4px;
  }

  .post-subtitle {
    font-size: 12px;
    font-weight: 600;
    color: var(--teal);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  /* Tablet */
  @media (min-width: 768px) and (max-width: 1023px) {
    .post-header {
      padding: 18px 20px;
    }

    .post-header h1 {
      font-size: 17px;
    }

    .post-layout {
      flex-direction: column;
    }
  }
</style>
