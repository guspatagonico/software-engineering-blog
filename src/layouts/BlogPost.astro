---
import '../styles/global.css';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import Head from '@/components/Head/Head.astro';
import { getPost } from '@/data/posts';

interface Props {
  title: string;
  subtitle?: string;
  description?: string;
}

const { title, subtitle, description } = Astro.props;

// Try to get description from posts.ts if not provided as prop
const postId = Astro.url.pathname.split('/').pop();
const post = postId ? getPost(postId) : undefined;
const finalDescription = description ?? post?.description;
---

<html lang="en">
  <head>
    <Head
      title={title}
      description={finalDescription}
      type="article"
      publishedTime={post?.pubDate}
    />
  </head>
  <body>
    <Navbar />
    <header class="post-header">
      <h1>{title}</h1>
      {subtitle && <span class="post-subtitle">{subtitle}</span>}
    </header>
    <div class="post-layout">
      <slot />
    </div>
    <Footer />
  </body>
</html>

<style>
  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .post-header {
    padding: 20px 28px 16px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: baseline;
    gap: 16px;
    background: var(--surface);
  }

  .post-header h1 {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-bright);
    letter-spacing: -0.4px;
  }

  .post-subtitle {
    font-size: 12px;
    font-weight: 600;
    color: var(--teal);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .post-layout {
    flex: 1;
    display: flex;
    min-height: 0;
  }

  /* Responsive */
  @media (max-width: 767px) {
    .post-header {
      padding: 16px;
      flex-direction: column;
      gap: 8px;
    }

    .post-header h1 {
      font-size: 16px;
    }

    .post-subtitle {
      font-size: 10px;
    }

    .post-layout {
      flex-direction: column;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .post-header {
      padding: 18px 20px;
    }

    .post-header h1 {
      font-size: 17px;
    }

    .post-layout {
      flex-direction: column;
    }
  }
</style>
