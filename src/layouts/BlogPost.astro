---
import '../styles/global.css';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import PostCompactFooter from '@/components/PostCompactFooter.astro';
import ScrollIndicator from '@/components/ScrollIndicator.astro';
import Head from '@/components/Head/Head.astro';
import type { PostMeta } from '@/data/posts';

interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  post?: PostMeta;
}

const { title, subtitle, description, post } = Astro.props;
const finalDescription = description ?? post?.description;
---

<html lang="en">
  <head>
    <Head
      title={title}
      description={finalDescription}
      type="article"
      publishedTime={post?.pubDate}
      tags={post?.tags}
    />
    <script is:inline>
      (function () {
        if (window.matchMedia('(max-width: 767px)').matches) {
          document.documentElement.dataset.sectionsCollapsed = 'true';
        }
      })();
    </script>
    <script is:inline>
      (function () {
        function moveTagsInline() {
          const tags = document.querySelector('[data-post-tags]');
          const content = document.querySelector('.content');
          if (!tags || !content) return;
          if (content.contains(tags)) return;
          tags.removeAttribute('hidden');
          content.appendChild(tags);
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', moveTagsInline);
        } else {
          moveTagsInline();
        }

        document.addEventListener('astro:page-load', moveTagsInline);
      })();
    </script>
    <script is:inline>
      (function () {
        document.documentElement.dataset.contentLoading = 'true';
        function clearLoading() {
          requestAnimationFrame(function () {
            delete document.documentElement.dataset.contentLoading;
          });
        }
        window.addEventListener('load', clearLoading, { once: true });
        document.addEventListener('astro:page-load', clearLoading, { once: true });
      })();
    </script>
    <script is:inline>
      (function () {
        const hash = window.location.hash.slice(1);
        if (hash) {
          document.documentElement.dataset.panelSyncing = 'true';
          document.documentElement.dataset.sectionsSyncing = 'true';
          document.documentElement.dataset.currentPanel = hash;
        }

        if (window.matchMedia('(max-width: 767px)').matches) {
          document.documentElement.dataset.sectionsCollapsed = 'true';
        }
      })();
    </script>
    <script is:inline>
      (function () {
        const root = document.documentElement;
        const threshold = 12;
        const mobileQuery = window.matchMedia('(max-width: 767px)');
        let lastCompact = null;

        function isMobile() {
          return mobileQuery.matches;
        }

        function getScrollTop() {
          const content = document.querySelector('.content');
          if (content && content.scrollHeight > content.clientHeight) return content.scrollTop;
          const layout = document.querySelector('.post-layout');
          if (layout && layout.scrollHeight > layout.clientHeight) return layout.scrollTop;
          return window.scrollY || document.documentElement.scrollTop;
        }

        function setHeaderHeight() {
          const header = document.querySelector('.post-header');
          if (!header) return;
          const height = Math.round(header.getBoundingClientRect().height);
          root.style.setProperty('--post-header-height', `${height}px`);
        }

        function updateCompact() {
          if (!isMobile()) {
            if (lastCompact !== false) {
              root.dataset.headerCompact = 'false';
              lastCompact = false;
              requestAnimationFrame(setHeaderHeight);
            }
            return;
          }

          const scrollTop = getScrollTop();
          const shouldCompact = scrollTop > threshold;
          if (shouldCompact !== lastCompact) {
            root.dataset.headerCompact = shouldCompact ? 'true' : 'false';
            lastCompact = shouldCompact;
            requestAnimationFrame(setHeaderHeight);
          }
        }

        function refresh() {
          bindListeners();
          setHeaderHeight();
          updateCompact();
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', refresh);
        } else {
          refresh();
        }

        function bindListeners() {
          const content = document.querySelector('.content');
          const layout = document.querySelector('.post-layout');
          if (content && content.dataset.headerCompactBound !== 'true') {
            content.dataset.headerCompactBound = 'true';
            content.addEventListener('scroll', updateCompact, { passive: true });
          }
          if (layout && layout.dataset.headerCompactBound !== 'true') {
            layout.dataset.headerCompactBound = 'true';
            layout.addEventListener('scroll', updateCompact, { passive: true });
          }
          if (root.dataset.headerCompactWindowBound !== 'true') {
            root.dataset.headerCompactWindowBound = 'true';
            window.addEventListener('scroll', updateCompact, { passive: true });
          }
        }

        window.addEventListener('load', refresh, { once: true });
        window.addEventListener('resize', refresh, { passive: true });
        document.addEventListener('astro:page-load', () => {
          setTimeout(refresh, 0);
        });
      })();
    </script>
    <style is:inline>
      @media (max-width: 767px) {
        :root:not([data-sections-collapsed='false']) .section-nav-toggle__label-text {
          display: none;
        }

        :root:not([data-sections-collapsed='false']) .section-nav-toggle__active {
          display: inline-flex;
        }

        :root:not([data-sections-collapsed='false']) .section-nav-toggle__icon {
          transform: rotate(0deg);
        }
      }
    </style>
  </head>
  <body class="post-page">
    <Navbar />
    <ScrollIndicator targetSelector=".content" position="fixed" top="48px" />
    <header class="post-header">
      <h1>{title}</h1>
      {subtitle && <span class="post-subtitle">{subtitle}</span>}
    </header>
    <div class="post-layout">
      <slot />
    </div>

    {post && <PostCompactFooter published={post.pubDate} />}

    {
      post && post.tags.length > 0 && (
        <div class="post-tags-inline" data-post-tags hidden>
          <span class="post-tags-inline__label">Tags</span>
          <div class="post-tags-inline__list">
            {post.tags.map((tag) => (
              <span class="post-tag">{tag}</span>
            ))}
          </div>
        </div>
      )
    }

    <Footer />

    <!-- Handle URL hash for section navigation -->
    <script is:inline>
      (function () {
        // Wait for React components to hydrate
        function initHashNavigation() {
          const hash = window.location.hash.slice(1);
          if (!hash) {
            delete document.documentElement.dataset.panelSyncing;
            delete document.documentElement.dataset.sectionsSyncing;
            return;
          }

          // Find the panel matching the hash
          const panel = document.getElementById('panel-' + hash);
          if (!panel) return;

          // Activate the panel
          document.querySelectorAll('.panel').forEach((p) => {
            p.classList.remove('active');
          });
          panel.classList.add('active');

          setTimeout(() => {
            const content = document.querySelector('.content');
            const scrollContainer = document.querySelector('.post-layout');

            if (content && content.scrollHeight > content.clientHeight) {
              content.scrollTo({ top: 0, behavior: 'smooth' });
            } else if (scrollContainer) {
              scrollContainer.scrollTo({ top: 0, behavior: 'smooth' });
            } else {
              window.scrollTo({ top: 0, behavior: 'smooth' });
            }
          }, 100);

          // Dispatch a custom event so SectionNav can sync its state
          window.dispatchEvent(
            new CustomEvent('section-activated', {
              detail: { sectionId: hash },
            })
          );

          delete document.documentElement.dataset.panelSyncing;
          delete document.documentElement.dataset.sectionsSyncing;
        }

        // Run on load and when DOM is ready
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initHashNavigation);
        } else {
          // Small delay to let React hydrate first
          setTimeout(initHashNavigation, 50);
        }

        // Also run after Astro page transitions
        document.addEventListener('astro:page-load', initHashNavigation);
      })();
    </script>
    <script src="/software-engineering/vendor/mermaid.min.js" defer></script>
    <script src="/software-engineering/vendor/mermaid-render.js" defer></script>
  </body>
</html>

<style>
  body {
    display: flex;
    flex-direction: column;
    height: 100dvh;
    overflow: hidden;
  }

  .post-page .footer {
    display: none;
  }

  .post-header {
    padding: 20px 28px 16px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: baseline;
    gap: 16px;
    background: var(--surface);
    position: sticky;
    top: 48px;
    z-index: 40;
    transition:
      padding 0.2s ease,
      gap 0.2s ease;
  }

  :root {
    --post-header-height: 60px;
  }

  .post-layout {
    flex: 1;
    display: flex;
    min-height: 0;
    position: relative;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .post-layout::-webkit-scrollbar {
    display: none;
  }

  /* Desktop: fixed section nav, scrolling content */
  @media (min-width: 1024px) {
    .post-layout {
      overflow: hidden;
    }

    .post-layout > nav {
      position: sticky;
      top: calc(48px + var(--post-header-height, 60px));
      height: calc(100vh - 48px - var(--post-header-height, 60px) - 70px);
      overflow-y: auto;
      flex-shrink: 0;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .post-layout > nav::-webkit-scrollbar {
      display: none;
    }
  }

  /* Tablet */
  @media (min-width: 768px) and (max-width: 1023px) {
    .post-layout {
      flex-direction: column;
      overflow-y: auto;
    }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .post-layout {
      flex-direction: column;
      overflow-y: auto;
      overscroll-behavior: none;
    }

    .post-header {
      padding: 16px;
      flex-direction: column;
      gap: 8px;
    }

    .post-header h1 {
      font-size: 16px;
    }

    .post-subtitle {
      font-size: 10px;
    }
  }

  .post-layout::-webkit-scrollbar {
    display: none;
  }

  .post-header h1 {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-bright);
    letter-spacing: -0.4px;
    transition:
      font-size 0.2s ease,
      line-height 0.2s ease;
  }

  .post-subtitle {
    font-size: 12px;
    font-weight: 600;
    color: var(--teal);
    letter-spacing: 2px;
    text-transform: uppercase;
    transition:
      font-size 0.2s ease,
      line-height 0.2s ease,
      letter-spacing 0.2s ease;
  }

  :root[data-header-compact='true'] .post-header {
    padding: 16px;
    gap: 10px;
  }

  :root[data-header-compact='true'] .post-header h1 {
    font-size: 16px;
    line-height: 22px;
  }

  :root[data-header-compact='true'] .post-subtitle {
    font-size: 10px;
    line-height: 14px;
    letter-spacing: 1.6px;
  }

  .mermaid {
    margin: 16px 0 18px;
    padding: 18px 20px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: linear-gradient(135deg, rgba(0, 212, 170, 0.08), rgba(10, 12, 18, 0));
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.12);
    overflow: auto;
  }

  .mermaid svg {
    display: block;
    width: 100%;
    height: auto;
    font-size: 14px;
    font-family: var(--font) !important;
  }

  .mermaid svg * {
    font-family: var(--font) !important;
  }

  .mermaid text,
  .mermaid tspan {
    font-family: var(--font);
    font-weight: 600;
    letter-spacing: 0.2px;
    font-size: 14px;
  }

  .mermaid .c4Container,
  .mermaid .c4Container * {
    font-size: 14px;
    font-family: var(--font) !important;
  }

  .mermaid .c4Container .label,
  .mermaid .c4Container .label text,
  .mermaid .c4Container .nodeLabel {
    font-weight: 600;
  }

  .mermaid .label text,
  .mermaid .nodeLabel {
    fill: var(--text-bright);
  }

  .mermaid .edgePath path {
    stroke: var(--text-dim);
  }

  .mermaid .edgeLabel {
    background: rgba(10, 12, 18, 0.85);
    border-radius: 6px;
    padding: 1px 6px;
  }

  .mermaid .node rect,
  .mermaid .node circle,
  .mermaid .node polygon,
  .mermaid .node path {
    stroke-width: 1.2px;
  }

  .mermaid .cluster rect {
    rx: 8px;
    ry: 8px;
  }

  :root[data-theme='light'] .mermaid {
    background: linear-gradient(135deg, rgba(0, 120, 96, 0.08), rgba(255, 255, 255, 0.7));
    border-color: rgba(0, 60, 48, 0.2);
  }

  :root[data-theme='light'] .mermaid .edgeLabel {
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(0, 60, 48, 0.15);
  }

  :root[data-theme='light'] .mermaid .edgePath path {
    stroke: rgba(0, 60, 48, 0.6);
  }

  :root[data-theme='dark'] .mermaid .edgeLabel {
    background: rgba(10, 12, 18, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  /* Tablet */
  @media (min-width: 768px) and (max-width: 1023px) {
    .post-header {
      padding: 18px 20px;
    }

    .post-header h1 {
      font-size: 17px;
    }

    .post-layout {
      flex-direction: column;
    }
  }

  @media (max-width: 767px) {
    .mermaid {
      padding: 14px 12px;
    }
  }
</style>
