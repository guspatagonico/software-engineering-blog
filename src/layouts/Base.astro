---
import '../styles/global.css';
import '../styles/page.css';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import Head from '@/components/Head/Head.astro';

interface Props {
  title: string;
  description?: string;
  isHome?: boolean;
}

const { title, description, isHome = false } = Astro.props;
---

<html lang="en">
  <head>
    <Head title={title} description={description} isHome={isHome} />
  </head>
  <body>
    <Navbar />
    <main class="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
  .main-content {
    flex: 1;
    padding: 32px;
    max-width: 720px;
  }

  /* Responsive */
  @media (max-width: 767px) {
    .main-content {
      padding: 20px 16px;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .main-content {
      padding: 24px 20px;
    }
  }
</style>
