---
import '../styles/global.css';
import '../styles/page.css';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import ScrollIndicator from '@/components/ScrollIndicator.astro';
import Head from '@/components/Head/Head.astro';

interface Props {
  title: string;
  description?: string;
  isHome?: boolean;
  showBackground?: boolean;
}

const { title, description, isHome = false, showBackground = false } = Astro.props;

import MatrixBackground from '@/components/MatrixBackground/MatrixBackground';
import Dodecahedron from '@/components/Dodecahedron/Dodecahedron';
---

<html lang="en">
  <head>
    <Head title={title} description={description} isHome={isHome} />
    <script is:inline>
      // Initialize matrix background state from localStorage or default to hidden
      function initMatrixState() {
        if (!document.body) {
          setTimeout(initMatrixState, 0);
          return;
        }
        const stored = localStorage.getItem('matrix-background-visible');
        const initialVisible = stored === 'true';
        document.body.classList.toggle('matrix-bg-visible', initialVisible);
        
        window.addEventListener('toggle-matrix-background', () => {
          const isVisible = document.body.classList.toggle('matrix-bg-visible');
          localStorage.setItem('matrix-background-visible', String(isVisible));
        });
      }
      
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initMatrixState);
      } else {
        initMatrixState();
      }
    </script>
    <style is:global>
      .dodecahedron-hidden {
        opacity: 0 !important;
        transition: opacity 0.5s ease !important;
        pointer-events: none !important;
      }
    </style>
  </head>
  <body>
    <div id="matrix-bg-wrapper" style="display: contents;">
      <MatrixBackground client:visible />
    </div>
    <Navbar />
    <ScrollIndicator targetSelector=".content" />
    <main class="page-container">
      <div class="content">
        <slot />
      </div>
    </main>
    <Footer />
    <Dodecahedron client:visible autoHideOnScroll={!isHome} />
  </body>
</html>

<style>
  body {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
    overflow: hidden;
  }
  .page-container {
    flex: 1;
    display: flex;
    justify-content: center;
    overflow: hidden;
    min-height: 0;
  }

  .content {
    width: 100%;
    max-width: 1024px;
    padding: 32px;
    overflow-y: auto;
    flex: 1;
    min-height: 0;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .content::-webkit-scrollbar {
    display: none;
  }

  /* Responsive */
  @media (max-width: 767px) {
    .content {
      padding: 20px 16px;
      -webkit-overflow-scrolling: touch;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .content {
      padding: 24px 20px;
    }
  }
</style>
