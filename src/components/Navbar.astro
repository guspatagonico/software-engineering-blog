---
import ThemeToggle from '@/components/ThemeToggle.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

interface Props {
  currentPath?: string;
}

const { currentPath } = Astro.props;

const links = [
  { href: `${base}/about`, label: 'About' },
  { href: `${base}/now`, label: 'Now' },
  { href: `${base}/contact`, label: 'Contact' },
];
---

<nav class="navbar">
  <a href={`${base}/`} class="navbar-logo" aria-label="Home">
    <span class="logo-mark">{'{ }'}</span>
    <span class="logo-text">SE Blog</span>
  </a>
  <div class="navbar-links">
    {
      links.map((link) => (
        <a href={link.href} class:list={['navbar-link', currentPath === link.href && 'active']}>
          {link.label}
        </a>
      ))
    }
    <ThemeToggle />
  </div>
</nav>

<style>
  .navbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 48px;
    padding: 0 28px;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }

  .navbar-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }

  .navbar-logo:hover {
    text-decoration: none;
  }

  .logo-mark {
    font-family: var(--font);
    font-size: 13px;
    font-weight: 700;
    color: var(--teal);
    background: rgba(0, 212, 170, 0.08);
    padding: 2px 6px;
    border-radius: 3px;
    line-height: 1;
  }

  .logo-text {
    font-size: 13px;
    font-weight: 700;
    color: var(--text-bright);
    letter-spacing: -0.3px;
  }

  .navbar-links {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .navbar-link {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    transition: color 0.15s;
    text-decoration: none;
  }

  .navbar-link:hover {
    color: var(--teal);
  }

  .navbar-link.active {
    color: var(--teal);
  }
</style>
