<script is:inline>
	(() => {
		const STAGES = ['orq', 'fork', 'sub', 'join', 'val', 'next'];
		const STEP_MS = 1200;

		const setStage = (diagram, stage) => {
			const tokens = diagram.querySelectorAll('.fj-stage-token');
			tokens.forEach((token) => token.classList.remove('is-on'));

			const active = diagram.querySelectorAll(`.fj-stage-token--${stage}`);
			active.forEach((token) => token.classList.add('is-on'));
		};

		const initDiagram = (diagram) => {
			if (diagram.dataset.fjInit === '1') return;
			diagram.dataset.fjInit = '1';

			setStage(diagram, 'orq');

			const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			if (reduceMotion) return;

			let index = 0;
			window.setInterval(() => {
				index = (index + 1) % STAGES.length;
				setStage(diagram, STAGES[index]);
			}, STEP_MS);
		};

		const run = () => {
			const diagrams = document.querySelectorAll('.fork-join-diagram');
			diagrams.forEach((diagram) => initDiagram(diagram));
		};

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', run, { once: true });
		} else {
			run();
		}
	})();
</script>

