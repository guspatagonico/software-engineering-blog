<script is:inline>
  function initDriftMap() {
    const map = document.querySelector('.drift-map');
    if (!map || map.dataset.initialized === 'true') return;
    map.dataset.initialized = 'true';

    const slider = map.querySelector('input[type="range"]');
    const value = map.querySelector('.drift-map__value');
    const tooltip = map.querySelector('.drift-tooltip');
    const cells = map.querySelectorAll('.drift-cell');

    if (!slider || !value || !tooltip) return;

    const sliderEl = slider;
    const valueEl = value;
    const tooltipEl = tooltip;
    const mapEl = map;

    function applyThreshold() {
      const threshold = Number(sliderEl.value);
      valueEl.textContent = String(threshold);
      cells.forEach((cell) => {
        const score = Number(cell.dataset.score || '0');
        cell.classList.toggle('is-muted', score < threshold);
      });
    }

    function showTooltip(event, cell) {
      const phase = cell.dataset.phase;
      const signal = cell.dataset.signal;
      const score = cell.dataset.score;
      const action = cell.dataset.action;
      tooltipEl.textContent = `${phase} · ${signal} · score ${score} · ${action}`;
      tooltipEl.style.opacity = '1';
      const rect = mapEl.getBoundingClientRect();
      tooltipEl.style.left = `${event.clientX - rect.left + 12}px`;
      tooltipEl.style.top = `${event.clientY - rect.top + 12}px`;
    }

    function hideTooltip() {
      tooltipEl.style.opacity = '0';
    }

    cells.forEach((cell) => {
      cell.addEventListener('mousemove', (event) => showTooltip(event, cell));
      cell.addEventListener('mouseleave', hideTooltip);
    });

    sliderEl.addEventListener('input', applyThreshold);
    applyThreshold();
  }

  document.addEventListener('astro:page-load', initDriftMap);
  initDriftMap();
</script>

