---
interface Props {
  targetSelector: string;
  position?: 'fixed' | 'absolute';
  top?: string;
  bottom?: string;
}

const { targetSelector, position = 'fixed', top = '48px', bottom } = Astro.props;

const style = position === 'fixed' ? `top: ${top}` : top ? `top: ${top}` : `bottom: ${bottom ?? 0}`;
---

<div class="scroll-indicator" data-target={targetSelector} style={style}>
  <div class="scroll-line"></div>
</div>

<script>
  function initScrollIndicator() {
    const indicator = document.querySelector('.scroll-indicator') as HTMLElement;
    if (!indicator) return;
    if (indicator.dataset.initialized === 'true') return;
    indicator.dataset.initialized = 'true';

    const targetSelector = indicator.dataset.target;

    // Helper: find the actually scrollable element
    function findScrollableElement(selector: string) {
      const el = document.querySelector(selector);
      if (!el) return null;
      const style = window.getComputedStyle(el);
      const isScrollable =
        style.overflow === 'auto' ||
        style.overflow === 'scroll' ||
        style.overflowY === 'auto' ||
        style.overflowY === 'scroll';
      return isScrollable ? el : null;
    }

    let target: HTMLElement | null = null;
    let resizeRaf = 0;

    function resolveTarget(): HTMLElement | null {
      let next = targetSelector ? findScrollableElement(targetSelector) : null;
      if (!next) next = findScrollableElement('.content');
      if (!next) next = findScrollableElement('.post-layout');
      if (!next) next = findScrollableElement('main');
      if (!next) next = document.body;
      return next as HTMLElement | null;
    }

    const line = indicator.querySelector('.scroll-line') as HTMLElement;
    if (!line) return;

    let lockCount = 0;

    function updateProgress() {
      if (!target) return;
      const targetEl = target;
      if (lockCount > 0) return;
      const scrollTop = targetEl.scrollTop;
      const scrollHeight = targetEl.scrollHeight - targetEl.clientHeight;

      if (scrollHeight <= 0) {
        line.style.width = '0%';
        return;
      }

      const progress = (scrollTop / scrollHeight) * 100;
      const next = Math.min(100, Math.max(0, progress));
      line.style.width = `${next}%`;
    }

    function setTarget(next: HTMLElement | null) {
      if (!next || next === target) return;
      if (target) target.removeEventListener('scroll', updateProgress);
      target = next;
      target.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();
    }

    setTarget(resolveTarget());
    window.addEventListener('section-nav-toggle', (event) => {
      const detail = (event as CustomEvent<{ isCollapsed: boolean }>).detail;
      if (!detail) return;

      if (!detail.isCollapsed) {
        lockCount += 1;
      } else if (lockCount > 0) {
        lockCount -= 1;
      }
    });

    window.addEventListener('section-activated', () => {
      lockCount = 0;
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          updateProgress();
        });
      });
    });
    function handleResize() {
      if (resizeRaf) cancelAnimationFrame(resizeRaf);
      resizeRaf = requestAnimationFrame(() => {
        setTarget(resolveTarget());
      });
    }

    window.addEventListener('resize', handleResize);
    updateProgress();
  }

  document.addEventListener('astro:page-load', initScrollIndicator);
  initScrollIndicator();
</script>

<style>
  .scroll-indicator {
    position: fixed;
    left: 0;
    right: 0;
    height: 3px;
    pointer-events: none;
    z-index: 100;
  }

  .scroll-line {
    height: 100%;
    width: 0%;
    background: var(--teal);
    transition: width 0.1s ease-out;
  }
</style>
